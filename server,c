#include<stdio.h>
#include<stdlib.h>
#include<sys/socket.h>
#include<unistd.h>
#include<sys/types.h>
#include<netinet/in.h>
#include<string.h>
#include<arpa/inet.h>
#include"online_dic.h"
#include <signal.h>
#include<sqlite3.h>

#define serv_ip "10.67.189.30"
#define serv_port 4999

int main(void){
    int sockfd, clientfd;
    struct sockaddr_in servaddr, clientaddr;
    char buf[132];
    Messg *messg;
    int ret;
    socklen_t peerlen;
    int pid;

    char sql[128];
    char **resultp;
    int nrow, cloumn;
    int i, j;
    int index = 0;
    sqlite3 *db;
    char *errmsg;

    USER user;
    char *history_messg;

    // 打开数据库
	if(sqlite3_open("my.db",&db)!=SQLITE_OK){
		printf("%s\n",sqlite3_errmsg(db));
		return 0;
	}else{
		printf("create database success\n");
	}


    if((sockfd=socket(AF_INET,SOCK_STREAM,0))==-1){
        perror("socket");
        return 0;
    }

    bzero(&servaddr, sizeof(servaddr));
    servaddr.sin_family = AF_INET;
    servaddr.sin_addr.s_addr = inet_addr(serv_ip);
    servaddr.sin_port = htons(serv_port);

    if((bind(sockfd,(struct sockaddr*)&servaddr,sizeof(servaddr)))<0){
        perror("bind");
        return 0;
    }

    if(listen(sockfd,10)==-1){
        perror("listen");
        return 0;
    }
    signal(SIGCHLD, SIG_IGN);

    peerlen = sizeof(clientaddr);


    while(1){
        if((clientfd=accept(sockfd,(struct sockaddr*)&clientaddr,&peerlen)<0)){
            perror("accept");
            return 0;
        }
        printf("connect from [%s:%d]\n", inet_ntoa(clientaddr.sin_addr), ntohs(clientaddr.sin_port));
        if((pid=fork())<0){
            perror("fork");
            continue;
        }
        if(pid==0){
            while((recv(sockfd,buf,132,0))>0){
                printf("%s\n", buf);
                messg = (Messg *)buf;
                printf("%d\n", messg->messg_type);
                printf("%s\n", messg->data.login_data.name);
                switch(messg->messg_type){
                    case 1:
                        sprintf(sql,"select * from user where name='%s';",messg->data.login_data.name);
						// 执行查询
						sqlite3_get_table(db,sql,&resultp,&nrow,&cloumn,&errmsg);

                        if (cloumn==0)
                        {
                            memset(buf, 0, 132);
                            strcpy(buf, "账号错误");
                            printf("%s\n", buf);
                            send(clientfd, buf, 132, 0);
                        }
                        else if(messg->data.login_data.passwaord==atoi(resultp[8])){
                            strcpy(user.name, messg->data.login_data.name);
                            user.password = messg->data.login_data.passwaord;

                            memset(buf, 0, 132);
                            strcpy(buf,"登录成功");
                            send(clientfd,buf,sizeof(buf),0);
                            for(i=0;i<5;i++){
								strcpy(user.history[i],resultp[9+i]);
							}
                        }
                        else{
                            memset(buf, 0, 132);
                            strcpy(buf, "密码错误");
                            send(clientfd, buf, 132, 0);
                        }
                        break;
                    
                    case 2: // 注册请求
						// 构建插入SQL语句
						sprintf(sql,"insert into user values('%s',%d,'a','a','a','a','a');",messg->data.login_data.name,messg->data.login_data.password);
						// 执行插入操作
						if(sqlite3_exec(db,sql,NULL,NULL,&errmsg)!=SQLITE_OK){
							printf("%s\n",errmsg);
							memset(buf,0,132);
							strcpy(buf,errmsg);
							send(clientfd,buf,sizeof(buf),0);
						}
						else{
							memset(buf,0,132);
							strcpy(buf,"注册成功");
							printf("%s\n",buf);
							send(clientfd,buf,sizeof(buf),0);
						}
						break;

					case 3: // 单词查询请求
						// 构建查询SQL语句
						sprintf(sql,"select * from stu where dictionary='%s';",messg->data.dictionary);
						// 执行查询
						sqlite3_get_table(db,sql,&resultp,&nrow,&cloumn,&errmsg);
						
						// 没有查到该单词
						if(cloumn==0){
							memset(buf,0,132);
							strcpy(buf,"没有查到该单词");
							printf("%s\n",buf);
							send(clientfd,buf,132,0);
						}
						// 查到单词，返回注释
						else{
							printf("%s\n",*(resultp+5));
							send(clientfd,resultp[5],256,0); // 给客户端发注释
							
							// 将记录存储到user结构体中，并对5个记录队列操作
							char temp1[24],temp2[24];
							strcpy(temp1,user.history[0]);
							strcpy(user.history[0],resultp[4]);
							for(i=1;i<5;i++){
								strcpy(temp2,user.history[i]);
								strcpy(user.history[i],temp1);
								strcpy(temp1,temp2);
							}
							// 将5个记录写入数据库中
							for(i=0;i<5;i++){
								sprintf(sql,"update user set history%d='%s' where name='%s';",(i+1),user.history[i],user.name);
								printf("%s\n",sql);
								if(sqlite3_exec(db,sql,NULL,NULL,&errmsg)!=SQLITE_OK){
									printf("%s\n",errmsg);
								}
								else{
									printf("历史记录写入成功\n");
								}
							}
						}
						
						break;
					case 4: // 历史记录查询请求
						
						// 将用户信息转换为字符指针
						history_messg=(char *)&user;
						// 发送历史记录
						send(clientfd,history_messg,256,0);
						
						break;
					default:
						break;

            }
        }
    }
    else{ // 进入父进程
			// 关闭连接的套接字
			close(clientfd);
        }
        }
	// 关闭监听套接字
	close(sockfd);
	return 0;


}